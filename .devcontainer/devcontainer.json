{
  "name": "Agno AgentOS Course",
  "dockerComposeFile": [
    "../compose.yaml",
    "compose.override.yaml"
  ],
  "service": "devcontainer",
  "workspaceFolder": "/workspace",
  "forwardPorts": [
    8000,
    5432
  ],
  "portsAttributes": {
    "8000": {
      "label": "AgentOS API",
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    }
  },
  "secrets": {
    "OPENAI_API_KEY": {
      "description": "Required for all agents and embeddings (text-embedding-3-small)"
    },
    "OLLAMA_API_KEY": {
      "description": "For Ollama-hosted models (glm-5.1:cloud). Optional."
    }
  },
  "remoteEnv": {
    "AGENTOS_URL": "https://${CODESPACE_NAME}-8000.${GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN}"
  },
  "postCreateCommand": "cp -n example.env .env && ./scripts/venv_setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        "charliermarsh.ruff",
        "redhat.vscode-yaml",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.codeActionsOnSave": {
            "source.fix": "explicit",
            "source.organizeImports": "explicit"
          }
        }
      }
    }
  }
}