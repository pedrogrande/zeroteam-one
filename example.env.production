# ---------------------------------------------------------------------------
# Railway Production Environment
# ---------------------------------------------------------------------------
# Copy this file to .env.production and fill in the values.
# .env.production is gitignored — it holds the secrets that
# ./scripts/railway/env-sync.sh pushes to the Railway agent-os service.
#
# Workflow:
#   1. cp example.env.production .env.production
#   2. Fill in the keys below
#   3. ./scripts/railway/up.sh        # first deploy (reads OPENAI_API_KEY + OLLAMA_API_KEY)
#   4. ./scripts/railway/env-sync.sh  # syncs everything in .env.production to Railway
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Required — model + embeddings
# ---------------------------------------------------------------------------
# OpenAI powers embeddings (text-embedding-3-small) for all knowledge bases.
OPENAI_API_KEY=sk-***

# Ollama Cloud powers the default model (glm-5.2:cloud).
# The Ollama client authenticates to https://ollama.com with this key.
OLLAMA_API_KEY=sk-***

# ---------------------------------------------------------------------------
# Required — web search (WebSearch + ThinkingPartner agents)
# Without this, ParallelTools logs an error and search calls fail.
# ---------------------------------------------------------------------------
PARALLEL_API_KEY=

# ---------------------------------------------------------------------------
# Runtime — JWT gate
# ---------------------------------------------------------------------------
# dev  = JWT authorization OFF (use for the initial deploy)
# prd  = JWT authorization ON (requires JWT_VERIFICATION_KEY below)
#
# The first deploy uses RUNTIME_ENV=dev (set by up.sh). Switch to prd
# once you've retrieved the JWT verification key from os.agno.com
# (Add OS → Live → Token Based Authorization) and synced it via env-sync.sh.
RUNTIME_ENV=dev

# Uncomment and paste the full PEM block when ready to enable JWT.
# Then set RUNTIME_ENV=prd above and run ./scripts/railway/env-sync.sh.
# JWT_VERIFICATION_KEY=-----BEGIN PUBLIC KEY-----
# MIIBIjANBgkq...
# -----END PUBLIC KEY-----

# ---------------------------------------------------------------------------
# AgentOS scheduler base URL
# ---------------------------------------------------------------------------
# Set to your Railway public domain after the first deploy creates it.
# The scheduler needs a publicly reachable URL so cron triggers hit the app.
# Leave as the default for the initial deploy; update + re-sync after up.sh.
AGENTOS_URL=http://127.0.0.1:8000

# ---------------------------------------------------------------------------
# Optional — Slack interface
# Set both to enable the Slack interface (routes to the CodeSearch agent).
# ---------------------------------------------------------------------------
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=

# ---------------------------------------------------------------------------
# Optional — model + embedder overrides
# ---------------------------------------------------------------------------
# AGENT_MODEL_ID=glm-5.2:cloud
# EMBEDDER_MODEL_ID=text-embedding-3-small

# ---------------------------------------------------------------------------
# Optional — tracing (needs an exporter configured to be useful)
# ---------------------------------------------------------------------------
# AGNO_TRACING=false

# ---------------------------------------------------------------------------
# Database — set by up.sh, listed here for reference.
# Don't set these in .env.production unless you want to override.
# ---------------------------------------------------------------------------
# DB_HOST=pgvector.railway.internal
# DB_PORT=5432
# DB_USER=ai
# DB_PASS=ai
# DB_DATABASE=ai
# DB_DRIVER=postgresql+psycopg
# WAIT_FOR_DB=True
# PORT=8000