# Railway Deployment Configuration
# Edit these values for your project, then run: ./scripts/railway_up.sh

# Project name (visible in Railway dashboard)
PROJECT_NAME="agent-os"

# Service name (the app service within the project)
SERVICE_NAME="agent-os"

# Database template ID (Railway's PgVector template)
DB_TEMPLATE_ID="3jJFCA"

# App port
PORT="8000"

# Seconds to wait for database before creating app service
DB_WAIT_TIME="10"
